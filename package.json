{
  "name": "bototo",
  "version": "1.0.0",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "concurrently \"node src/index.js\" \"cd dashboard && npm start\"",
    "dev": "concurrently \"node --watch src/index.js\" \"cd dashboard && npm start\"",
    "dashboard": "cd dashboard && npm start",
    "server": "node src/server.js",
    "install:all": "npm install && cd dashboard && npm install"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "baileys",
    "chatbot",
    "conversation-tree"
  ],
  "author": "",
  "license": "ISC",
  "description": "WhatsApp bot with reusable conversation trees and full error handling",
  "dependencies": {
    "@clerk/express": "^2.0.7",
    "@hapi/boom": "^10.0.1",
    "@supabase/supabase-js": "^2.100.1",
    "@whiskeysockets/baileys": "6.6.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "mercadopago": "^2.12.0",
    "mongodb": "^5.9.2",
    "multer": "^2.1.1",
    "pino": "^10.0.0",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  }
}
