# PeronBot Environment Variables

# Server Port (Different from Next.js to avoid conflicts)
PORT=8000

# Frontend Domain (Next.js)
FRONTEND_DOMAIN=http://localhost:3000

# Backend Domain (Deno/Express)
BACKEND_DOMAIN=http://localhost:8000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/peronbot

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Supabase (Optional)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxx

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WhatsApp Bot Configuration
WHATSAPP_SESSION_FOLDER=baileys_auth_info
WHATSAPP_QR_TIMEOUT=60000
WHATSAPP_RECONNECT_DELAY=3000

# API Keys
TU_API_KEY_SECRETA=your-secret-api-key

# MercadoPago
MERCADO_PAGO_PUBLIC_KEY=your-mercado-pago-public-key
MERCADO_PAGO_ACCESS_TOKEN=your-mercado-pago-access-token
MERCADO_PAGO_MODE=sandbox
