# Bototo - WhatsApp Bot Configuration
# Copy this file to .env and fill in your values

# ===========================================
# MONGODB CONFIGURATION
# ===========================================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/bototo
# Database name
MONGODB_DB=bototo

# ===========================================
# BOT CONFIGURATION
# ===========================================
# Bot name (display name)
BOT_NAME=Bototo
# Browser name (for WhatsApp)
BROWSER_NAME=Bototo-Bot
# Browser version
BROWSER_VERSION=1.0
# Use mobile mode (true/false)
BOT_MOBILE=false
# Command prefix
COMMAND_PREFIX=!

# ===========================================
# SESSION CONFIGURATION
# ===========================================
# Folder to store session files
SESSION_FOLDER=baileys_auth_info

# ===========================================
# CONNECTION CONFIGURATION
# ===========================================
# Connection timeout in milliseconds
CONNECTION_TIMEOUT=60000
# Delay between reconnection attempts (ms)
RETRY_DELAY=3000
# Maximum number of reconnection attempts
MAX_RETRIES=5

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co
# Supabase anon/public key
SUPABASE_KEY=your-supabase-anon-key
# Storage bucket name for file uploads
SUPABASE_BUCKET=files

# ===========================================
# CLERK AUTHENTICATION CONFIGURATION
# ===========================================
# Clerk publishable key (from Clerk Dashboard)
CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
# Clerk secret key (from Clerk Dashboard)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
# Clerk webhook secret (for verifying webhooks)
CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret
